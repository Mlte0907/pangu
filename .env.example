# 盘古配置示例 — 复制为 .env 后填入实际值

# ── 基础服务 ──
PANGU_HOST=0.0.0.0
PANGU_PORT=19528
PANGU_WEB_HOST=0.0.0.0
PANGU_WEB_PORT=8866
PANGU_API_KEY=your-secret-api-key-change-me

# ── LLM 配置（至少填一个） ──
PANGU_LLM_PROVIDER=openai
PANGU_LLM_MODEL=gpt-4o-mini
PANGU_LLM_API_KEY=sk-your-openai-key
# PANGU_LLM_BASE_URL=  # 自定义网关

# ── 嵌入模型（可选：API 优先） ──
PANGU_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# PANGU_EMBED_API_URL=https://your-embed-api.com/v1/embeddings
# PANGU_EMBED_API_MODEL=text-embedding-3-small

# ── 监控 ──
PANGU_PROMETHEUS_ENABLED=true

# ── Grafana ──
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
