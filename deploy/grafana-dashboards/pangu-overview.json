    {
      "id": 22,
      "title": "搜索 vs 创建 vs 删除",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 23},
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2}}
      },
      "targets": [
        {"expr": "rate(pangu_memory_search_total[5m])", "refId": "A", "legendFormat": "搜索"},
        {"expr": "sum(rate(pangu_memory_created_total[5m]))", "refId": "B", "legendFormat": "创建"},
        {"expr": "rate(pangu_memory_deleted_total[5m])", "refId": "C", "legendFormat": "删除"}
      ]
    },
    {
      "id": 23,
      "title": "引擎执行时长 P95（按引擎）",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 31},
      "options": {
        "legend": {"displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineWidth": 2}}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, engine_name) (rate(pangu_engine_run_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{engine_name}}"
        }
      ]
    },
    {
      "id": 24,
      "title": "引擎错误率",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 31},
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "fillOpacity": 60, "stacking": {"mode": "normal"}}}
      },
      "targets": [
        {
          "expr": "sum by (engine_name) (rate(pangu_engine_errors_total[5m]))",
          "refId": "A",
          "legendFormat": "{{engine_name}}"
        }
      ]
    },

    {
      "type": "row",
      "id": 103,
      "title": "🧬 嵌入服务（Embedding）",
