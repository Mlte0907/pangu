# 盘古 v3.0 环境变量配置
# =====================================
# 复制此文件为 .env 并修改需要的配置
# 复制: cp env.example .env

# ── 服务配置 ──
PANGU_HOST=127.0.0.1
PANGU_PORT=19529
PANGU_LOG_LEVEL=INFO

# ── 数据目录 ──
PANGU_BASE_DIR=~/.pangu

# ── LLM 配置 ──
PANGU_LLM_PROVIDER=openai          # openai / ollama / deepseek / zhipu
PANGU_LLM_MODEL=gpt-4o             # 模型名称
PANGU_LLM_API_KEY=                 # API 密钥（留空则不启用）
PANGU_LLM_BASE_URL=                # 自定义 API 地址（可选）

# ── 嵌入配置 ──
PANGU_EMBED_API_URL=                # 嵌入 API 地址（留空则使用 ONNX 本地推理）
PANGU_ONNX_ENABLED=true            # 启用 ONNX 本地嵌入

# ── 安全配置 ──
PANGU_API_KEY=                      # API 密钥（留空则不启用鉴权）
PANGU_JWT_SECRET=                   # JWT 密钥（留空则自动生成）

# ── 性能配置 ──
PANGU_CONSOLIDATION_ENABLED=true   # 启用记忆巩固
PANGU_ONNX_MODEL_ID=Xenova/all-MiniLM-L6-v2  # ONNX 模型
PANGU_ONNX_QUANTIZED=true          # 使用量化模型
